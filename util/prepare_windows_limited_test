#!/usr/bin/env bash
# Adds the embedded PostgreSQL paths needed by Windows tests, then delegates
# the PsExec -l launcher setup to prepare_windows_limited_process.

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
launcher="${1:?usage: prepare_windows_limited_test <launcher.cmd>}"
: "${LIMITED_TEST_COMMAND:?LIMITED_TEST_COMMAND must be set}"
: "${RUNNER_TEMP:?RUNNER_TEMP must be set}"

runner_temp_msys="$(cygpath -u "$RUNNER_TEMP")"
test_work_msys="$runner_temp_msys/limited-test"
test_data_path_win="$(cygpath -m "$test_work_msys/pgdata")"

# BinaryStore should only need to read the seeded cache. Keep it writable by
# the limited process as well so lock or metadata recovery cannot fail solely
# because the action unpacked it with the runner's normal integrity level.
if [[ -d .pg-cache ]]; then
  MSYS2_ARG_CONV_EXCL='*' icacls.exe "$(cygpath -w "$PWD/.pg-cache")" \
    /setintegritylevel '(OI)(CI)L' /t /c /q
fi

LIMITED_PROCESS_WORK_NAME=limited-test \
LIMITED_PROCESS_LOG_NAME=output.log \
LIMITED_PROCESS_COMMAND="set \"SERVERPOD_DATABASE_DATA_PATH=$test_data_path_win\"
$LIMITED_TEST_COMMAND" \
  "$HERE/prepare_windows_limited_process" "$launcher"

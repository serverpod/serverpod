#!/usr/bin/env bash
# Adds the embedded PostgreSQL paths needed by Windows tests, then delegates
# the PsExec -l launcher setup to prepare_windows_limited_process.

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
launcher="${1:?usage: prepare_windows_limited_test <launcher.cmd>}"
: "${LIMITED_TEST_COMMAND:?LIMITED_TEST_COMMAND must be set}"
: "${RUNNER_TEMP:?RUNNER_TEMP must be set}"
: "${PUB_CACHE:?PUB_CACHE must be set}"

runner_temp_msys="$(cygpath -u "$RUNNER_TEMP")"
test_work_msys="$runner_temp_msys/limited-test"
test_data_path_win="$(cygpath -m "$test_work_msys/pgdata")"

make_low_integrity_writable() {
  local path="$1"
  [[ -d "$path" ]] || return 0
  MSYS2_ARG_CONV_EXCL='*' icacls.exe "$(cygpath -w "$path")" \
    /setintegritylevel '(OI)(CI)L' /t /c /q
}

# PsExec's Low Integrity token should otherwise behave like the developer who
# owns a normal checkout. Tests and Dart tooling may update lockfiles, generated
# sources, and build-hook state anywhere in this ephemeral CI checkout, so give
# the limited process the same write access throughout it.
make_low_integrity_writable "$PWD"

# Package downloads live outside the checkout and may also be updated while
# Dart starts a test process.
pub_cache_msys="$(cygpath -u "$PUB_CACHE")"
mkdir -p "$pub_cache_msys"
make_low_integrity_writable "$pub_cache_msys"

# Project creation resolves generated workspaces with `flutter pub get` when
# Flutter is available. The Flutter tool takes locks and updates stamps in its
# own mutable cache, which must therefore be writable by the limited process.
if [[ -n "${FLUTTER_ROOT:-}" ]]; then
  flutter_cache_msys="$(cygpath -u "$FLUTTER_ROOT")/bin/cache"
  make_low_integrity_writable "$flutter_cache_msys"
fi

LIMITED_PROCESS_WORK_NAME=limited-test \
LIMITED_PROCESS_LOG_NAME=output.log \
LIMITED_PROCESS_COMMAND="set \"SERVERPOD_DATABASE_DATA_PATH=$test_data_path_win\"
$LIMITED_TEST_COMMAND" \
  "$HERE/prepare_windows_limited_process" "$launcher"

#!/bin/bash

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_sqlite_migrations_e2e"
    exit 1
fi

# Makes script exit on first non-zero error code
set -e

# Bind mount targets must exist (directory for sqlite_data so WAL/SHM stay shared).
mkdir -p tests/serverpod_test_sqlite/serverpod_test_sqlite_server/sqlite_data

cd tests/docker/tests_sqlite_e2e_migrations

docker compose --progress quiet up \
  --abort-on-container-exit \
  --exit-code-from tests \
  --build \
  --remove-orphans

#!/bin/bash

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/generate_all"
    exit 1
fi

# Makes script exit on first non-zero error code
set -e

. "util/all_packages"

BASE=`pwd`
CLI_DIR=$BASE/tools/serverpod_cli
CLI=$CLI_DIR/bin/serverpod_cli.dart

echo "pub get cli"
cd $CLI_DIR
dart pub get

# Attempt to generate all server packages
for path in "${SERVERPOD_SERVER_PATHS[@]}"; do
    echo "### $path"
    cd "$BASE/$path"

    dart $CLI generate --no-analytics
done


# Templates (modulename_server, projectname_server, projectname_server_upgrade).
# Extracted to util/generate_templates so the CI "serverpod generate (templates)"
# job runs exactly the same logic - here against the from-source CLI (the script's
# default), in CI against the prebuilt CLI bundle via SERVERPOD_CLI_CMD.
cd "$BASE"
util/generate_templates

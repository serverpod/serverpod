#!/usr/bin/env bash
# Prepares a command wrapper for a process that must run through PsExec on a
# Windows GitHub Actions runner.

set -euo pipefail

launcher="${1:?usage: prepare_windows_psexec_process <launcher.cmd>}"
: "${PSEXEC_PROCESS_COMMAND:?PSEXEC_PROCESS_COMMAND must be set}"
: "${RUNNER_TEMP:?RUNNER_TEMP must be set}"

work_name="${PSEXEC_PROCESS_WORK_NAME:-psexec-process}"
log_name="${PSEXEC_PROCESS_LOG_NAME:-output.log}"
if [[ "$work_name" == */* || "$work_name" == *\\* ||
      "$log_name" == */* || "$log_name" == *\\* ]]; then
  echo "Work and log names must not contain path separators" >&2
  exit 1
fi

launcher_msys="$(cygpath -a -u "$launcher")"
command_msys="${launcher_msys%.cmd}-command.cmd"
command_win="$(cygpath -w "$command_msys")"
run_directory_win="$(cygpath -w "$PWD")"

runner_temp_msys="$(cygpath -u "$RUNNER_TEMP")"
process_work_msys="$runner_temp_msys/$work_name"
process_work_win="$(cygpath -w "$process_work_msys")"
process_log_msys="$process_work_msys/$log_name"
process_log_win="$(cygpath -w "$process_log_msys")"

# PsExec may use a Low Integrity token. Lowering this work directory's
# integrity level keeps it writable by both limited processes and the standard
# test account used by the Dart test jobs.
mkdir -p "$process_work_msys"
rm -f "$process_log_msys"
MSYS2_ARG_CONV_EXCL='*' icacls.exe "$process_work_win" \
  /setintegritylevel '(OI)(CI)L'

# Keep the process command separate from the launcher so commands containing
# operators such as `&&` are interpreted exactly as supplied by the caller.
cat > "$command_msys" <<EOF
@echo off
$PSEXEC_PROCESS_COMMAND
EOF

cat > "$launcher_msys" <<EOF
@echo off
setlocal
set "TEMP=$process_work_win"
set "TMP=$process_work_win"
set "TMPDIR=$process_work_msys"
cd /d "$run_directory_win"
call "$command_win" > "$process_log_win" 2>&1
set "RC=%errorlevel%"
exit /b %RC%
EOF

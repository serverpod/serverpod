#!/bin/bash

# De-dockerized Serverpod e2e WEB tests: the client suite compiled to JS and run
# in Firefox (headless via xvfb) against a host server on embedded PostgreSQL -
# replacing the Docker compose stack in tests/docker/tests_e2e.
#
# The CI job (see .github/workflows/dart-tests.yaml) provides:
#   - the seeded embedded PostgreSQL bundle (SERVERPOD_PG_CACHE_DIR),
#   - the prebuilt server bundle (SERVERPOD_POD_BUNDLE, from build_pod), and
#   - an /etc/hosts alias mapping `serverpod_test_server` to 127.0.0.1, so the
#     hardcoded client URLs (test_util/config.dart) resolve to the host server
#     with no source changes.
#
# Redis is disabled here and redis_test.dart is excluded: it is the only e2e file
# that uses Redis, and its cache round-trip is a server-side behaviour already
# covered by the IO e2e suite - not worth provisioning a Redis just to re-check it
# over the browser transport.

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_e2e_web"
    exit 1
fi

set -e
export SERVERPOD_SILENCE_LIFECYCLE_MESSAGES="1"
export SERVERPOD_DATABASE_DATA_PATH=".serverpod/test/pgdata"
export SERVERPOD_REDIS_ENABLED="false"
# Embedded PG runs the server in the host timezone; pin UTC to match the former
# container (which ran UTC).
export TZ="UTC"

# Whole-file sharding for parallel CI jobs: pass <shard-index> <total-shards>
# (0-based index, default 0 1 = a single shard). The e2e suite shares one server
# + database (--concurrency=1 below), so we parallelise across shards - each shard
# is its own job with its own server + embedded database.
shard_index="${1:-0}"
total_shards="${2:-1}"

cd tests/serverpod_test_server
rm -rf "$SERVERPOD_DATABASE_DATA_PATH"

# Obtain the server bundle. It carries its OWN sqlite3 native lib (isolated from
# the `dart test` run's native-asset rebuilds, which would otherwise segfault the
# running server). CI prebuilds it once in build_pod and points SERVERPOD_POD_BUNDLE
# at the unpacked bundle; a local run builds it here.
if [ -n "$SERVERPOD_POD_BUNDLE" ]; then
    echo "### Using prebuilt server bundle from $SERVERPOD_POD_BUNDLE"
    SERVER_EXE="$(echo "$SERVERPOD_POD_BUNDLE"/bin/*)"
else
    echo "### Building the test server bundle"
    rm -rf .dart_tool/server_bundle
    dart build cli -t bin/main.dart -o .dart_tool/server_bundle
    SERVER_EXE="$(echo .dart_tool/server_bundle/bundle/bin/*)"
fi

# Start the server in the background; it applies migrations on boot and serves the
# API the e2e client suite drives.
echo "### Starting test server"
"$SERVER_EXE" -m production --apply-migrations &
SERVER_PID=$!
cleanup() {
    kill "$SERVER_PID" 2>/dev/null || true
    for port in 8080 8081 8082; do
        lsof -ti "tcp:$port" 2>/dev/null | xargs -r kill 2>/dev/null || true
    done
}
trap cleanup EXIT

# Wait for the api server (localhost:8080) to accept connections.
echo "### Waiting for the server on localhost:8080"
for _ in $(seq 1 60); do
    if (exec 3<>/dev/tcp/localhost/8080) 2>/dev/null; then
        exec 3>&- 3<&-
        echo "### Server is up"
        break
    fi
    sleep 1
done

# Assign whole test files to this shard, round-robin.
shard_test_files=()
file_i=0
while IFS= read -r test_file; do
    if [ "$total_shards" -le 1 ] || [ $(( file_i % total_shards )) -eq "$shard_index" ]; then
        shard_test_files+=("$test_file")
    fi
    file_i=$(( file_i + 1 ))
done < <(find test_e2e -name '*_test.dart' ! -name 'redis_test.dart' | sort)
if [ ${#shard_test_files[@]} -eq 0 ]; then
    echo "### No test files assigned to shard $shard_index/$total_shards"
    exit 0
fi

# Run the e2e tests in Firefox, headless via xvfb. --concurrency=1: the suite
# shares the one server + database.
echo "### Running e2e web tests (${#shard_test_files[@]} files, shard $shard_index/$total_shards)"
xvfb-run -a dart test "${shard_test_files[@]}" --concurrency=1 -p firefox --reporter=failures-only

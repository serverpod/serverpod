#!/bin/bash

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/publish_all"
    exit 1
fi

BASE=`pwd`
CLI_DIR=$BASE/tools/serverpod_cli
CLI=$CLI_DIR/bin/serverpod_cli.dart

echo "pub get cli"
cd $CLI_DIR
dart pub get
cd $BASE

# Parse command line arguments
PCOUNT_START_DEFAULT=0
SLEEP_TIME_DEFAULT=5
PCOUNT_START=$PCOUNT_START_DEFAULT
SLEEP_TIME=$SLEEP_TIME_DEFAULT
FORCE_FLAG=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --start)
      if [[ -z "$2" ]]; then
        echo "Error: --start requires a value"
        echo "Usage: $0 [--start N] [--sleep N] [--force]"
        exit 1
      fi
      if ! [[ "$2" =~ ^[0-9]+$ ]]; then
        echo "Error: --start must be a non-negative integer"
        exit 1
      fi
      PCOUNT_START="$2"
      shift 2
      ;;
    --sleep)
      if [[ -z "$2" ]]; then
        echo "Error: --sleep requires a value"
        echo "Usage: $0 [--start N] [--sleep N] [--force]"
        exit 1
      fi
      if ! [[ "$2" =~ ^[0-9]+$ ]]; then
        echo "Error: --sleep must be a non-negative integer"
        exit 1
      fi
      SLEEP_TIME="$2"
      shift 2
      ;;
    --force)
      FORCE_FLAG="--force"
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [--start N] [--sleep N] [--force]"
      exit 1
      ;;
  esac
done

echo "### START PUBLISHING"

echo "Base directory $BASE"
echo "Start at package $PCOUNT_START"
echo "Sleep time between packages: $SLEEP_TIME seconds"
if [[ -n "$FORCE_FLAG" ]]; then
  echo "Force publish: enabled"
else
  echo "Force publish: disabled"
fi

VERSION=`cat SERVERPOD_VERSION`
DART_VERSION=`cat DART_VERSION`
FLUTTER_VERSION=`cat FLUTTER_VERSION`

if test -z "$VERSION"
then
  echo "Version number is not defined"
  exit
fi

if [[ $(git diff --stat) != '' ]]; then
  echo 'Git is dirty. Please commit all changes before publishing.'
  exit
else
  echo 'Git is clean'
fi

echo "Publish Serverpod version $VERSION (Dart version: $DART_VERSION, Flutter version: $FLUTTER_VERSION)"

echo "Updating pubspecs"
cd $BASE
dart $CLI generate-pubspecs --version "$VERSION" --dart-version "$DART_VERSION" --flutter-version "$FLUTTER_VERSION" --mode production

echo "Publish packages"

PCOUNT=0
while read PACKAGE <&3; do
  if (($PCOUNT >= $PCOUNT_START));
  then
    echo "### PUBLISH PACKAGE: $PCOUNT"
    echo "$PACKAGE"
    cd $BASE/$PACKAGE
    dart pub publish $FORCE_FLAG

    if (($? != 0));
    then
      echo ""
      echo "### PUBLISH FAILED: $PCOUNT"
      echo "Fix issues, then resume by running"
      if [[ -n "$FORCE_FLAG" ]]; then
        echo "util/publish_all --start $PCOUNT --sleep $SLEEP_TIME --force"
      else
        echo "util/publish_all --start $PCOUNT --sleep $SLEEP_TIME"
      fi
      echo ""
      echo ""
      break
    fi

    # Give pub.dev a chance to catch up between each package deployment
    echo ""
    sleep $SLEEP_TIME
  else
    echo "### SKIPPING PACKAGE: $PCOUNT"
    echo "$PACKAGE"
    echo ""
  fi
  PCOUNT=$((PCOUNT+1))
done 3<PUBLISHABLE_PACKAGES

echo "Restore pubspecs"
cd $BASE
git reset --hard HEAD

echo "dart pub get"
util/pub_get_all

#!/bin/bash

# Runs the serverpod_test_module_server integration tests against an
# embedded PostgreSQL postmaster (no Docker required).
#
# Uses serverpod_embedded_postgres:wrap as a slim entry point that boots
# PG, runs `dart test`, and stops PG in a single Dart VM. Avoids the
# ~25s/~25s of build-hook overhead that two separate `serverpod
# embedded-pg start/stop` invocations would pay.

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_module_integration_embedded"
    exit 1
fi

set -e
export SERVERPOD_SILENCE_LIFECYCLE_MESSAGES="1"

REPO_ROOT="$(pwd)"
WRAP="$REPO_ROOT/packages/serverpod_embedded_postgres/bin/wrap.dart"
MODULE_DIR="tests/serverpod_test_module/serverpod_test_module_server"

dart run "$WRAP" \
    --module-dir="$MODULE_DIR" \
    --tcp \
    --port=9090 \
    --db-name='serverpod_test_module_test' \
    --password='DB_TEST_PASSWORD' \
    -- \
    dart test \
        -t integration \
        -x concurrency_one \
        --reporter=failures-only \
        "$@"

#!/bin/bash

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_bootstrap"
    exit 1
fi

export SERVERPOD_SILENCE_LIFECYCLE_MESSAGES="1"

# Makes script exit on first non-zero error code
set -e

# Optional sharding for parallel CI jobs: pass <shard-index> <total-shards>
# (0-based index). Defaults to a single shard, so non-sharded callers are
# unchanged. Both suites below are sharded independently.
shard_index="${1:-0}"
total_shards="${2:-1}"
shard_args=()
if [ "$total_shards" -gt 1 ]; then
    shard_args=(--total-shards "$total_shards" --shard-index "$shard_index")
fi

export SERVERPOD_HOME=$(pwd)
cd tests/bootstrap_project

# Run bootstrap tests
dart test --reporter=failures-only "${shard_args[@]}"

# Run performCreate tests
dart test test_perform_create --reporter=failures-only "${shard_args[@]}"

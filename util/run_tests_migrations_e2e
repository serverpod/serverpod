#!/bin/bash

# Runs the serverpod_test_server migration e2e tests on the host - no Docker
# required. They run against an embedded PostgreSQL postmaster (built once by
# seed_embedded_pg, like the other host integration suites) instead of a Docker
# postgres. The tests inspect and reset the live database through the insights
# API, so a server is started in the background; it shares the embedded
# postmaster with the create-migration and apply-migrations steps the tests
# spawn. The migration tests neither use nor are tagged `redis`, so Redis is
# disabled on the server (SERVERPOD_REDIS_ENABLED=false) and none is needed.

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_migrations_e2e"
    exit 1
fi

# Makes script exit on first non-zero error code
set -e
export SERVERPOD_SILENCE_LIFECYCLE_MESSAGES="1"
export SERVERPOD_DATABASE_DATA_PATH=".serverpod/test/pgdata"
export SERVERPOD_REDIS_ENABLED="false"
# The Dockerised suites reach the server as `serverpod_test_server`; on the host
# it runs on localhost (see test_util/service_client.dart).
export SERVERPOD_TEST_SERVICE_URL="http://localhost:8081/"
# Embedded PG runs the server in the host timezone; pin UTC so timezone-sensitive
# behaviour matches the former container (which ran UTC).
export TZ="UTC"

# Optional sharding for parallel CI jobs: pass <shard-index> <total-shards>
# (0-based index). Defaults to a single shard, so non-sharded callers are
# unchanged.
shard_index="${1:-0}"
total_shards="${2:-1}"
shard_args=()
if [ "$total_shards" -gt 1 ]; then
    shard_args=(--total-shards "$total_shards" --shard-index "$shard_index")
fi

cd tests/serverpod_test_server
rm -rf "$SERVERPOD_DATABASE_DATA_PATH"

# Build the server into a standalone bundle so it carries its OWN copy of the
# sqlite3 native library. (serverpod_test_server pulls in sqlite3 for SQLite
# support even though this suite runs on Postgres.) Running it via `dart run`
# shares .dart_tool/native_assets with the `dart test` run below, and `dart test`
# re-links sqlite3 there while the server holds the old copy mapped - which
# segfaults the running server (SEGV_MAPERR). The bundle's lib/ is isolated from
# those rebuilds.
echo "### Building the test server bundle"
rm -rf .dart_tool/server_bundle
dart build cli -t bin/main.dart -o .dart_tool/server_bundle
SERVER_EXE="$(echo .dart_tool/server_bundle/bundle/bin/*)"

# Start the bundled server in the background; it applies migrations on boot and
# serves the insights API the tests use to inspect/reset the live database.
echo "### Starting test server"
"$SERVER_EXE" -m production --apply-migrations &
SERVER_PID=$!
# The bundled exe is the server process directly (no `dart run` wrapper), so
# killing it suffices; the port sweep is a belt-and-suspenders fallback.
cleanup() {
    kill "$SERVER_PID" 2>/dev/null || true
    for port in 8080 8081 8082; do
        lsof -ti "tcp:$port" 2>/dev/null | xargs -r kill 2>/dev/null || true
    done
}
trap cleanup EXIT

# Wait for the insights server (localhost:8081) to accept connections.
echo "### Waiting for the insights server on localhost:8081"
for _ in $(seq 1 60); do
    if (exec 3<>/dev/tcp/localhost/8081) 2>/dev/null; then
        exec 3>&- 3<&-
        echo "### Server is up"
        break
    fi
    sleep 1
done

# Run the migration e2e tests.
echo "### Running migration e2e tests"
dart test test_e2e_migrations --concurrency=1 --reporter=failures-only "${shard_args[@]}"

#!/bin/bash

# Runs the serverpod_test_sqlite_server integration tests on the host - no Docker
# required. SQLite is file-based, so the apply-migrations step and the
# withServerpod tests share the database files under sqlite_data/ on the same
# filesystem. These tests are not safe to run concurrently, hence
# `--concurrency=1`; all tests tagged 'integration' (the test-tools default) are
# excluded here.

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_sqlite_integration"
    exit 1
fi

# Makes script exit on first non-zero error code
set -e
export SERVERPOD_SILENCE_LIFECYCLE_MESSAGES="1"

cd tests/serverpod_test_sqlite/serverpod_test_sqlite_server

# Reset the database (SQLite files under sqlite_data/).
echo "### Resetting SQLite database"
rm -f sqlite_data/*.db*

# Apply migrations to the database (maintenance role applies and exits).
echo "### Apply migrations"
dart run bin/main.dart -m production -r maintenance --apply-migrations

# Run tests.
echo "### Running integration tests"
dart test test_integration --concurrency=1 --reporter=failures-only

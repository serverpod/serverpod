#!/bin/bash

# Runs the serverpod_test_nonvector_server integration tests against an
# embedded PostgreSQL postmaster (no Docker required).
#
# The nonvector server's test.yaml has 'redis: enabled: true' but its
# integration tests do not exercise any redis-backed feature. withServerpod
# logs Redis connection failures during startup but those don't fail the
# test - the framework treats redis as best-effort at the connection level.

if [ ! -f util/.serverpod_util_root ]; then
    echo "Run this script from the root of the Serverpod repository"
    echo "I.e. util/run_tests_nonvector_integration_embedded"
    exit 1
fi

set -e
export SERVERPOD_SILENCE_LIFECYCLE_MESSAGES="1"
export SERVERPOD_DATABASE_DATA_PATH=".serverpod/test/pgdata"

REPO_ROOT="$(pwd)"

cd "tests/serverpod_test_nonvector/serverpod_test_nonvector_server"

dart test -t integration --reporter=failures-only

# Verify that the database data path exists
if [ ! -d "$SERVERPOD_DATABASE_DATA_PATH" ]; then
    echo "Test did not create the database data path: $SERVERPOD_DATABASE_DATA_PATH"
    cd "$REPO_ROOT"
    exit 1
fi

# Remove the database data path
rm -rf "$SERVERPOD_DATABASE_DATA_PATH"

cd "$REPO_ROOT"

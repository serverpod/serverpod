{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "serverpod_start_watch",
            "type": "shell",
            "command": "serverpod start --watch --no-fes",
            "isBackground": true,
            "options": {
                "cwd": "${workspaceFolder}/projectname_server"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Starting server in watch mode",
                    "endsPattern": "Server running"
                }
            }
        }
    ]
}

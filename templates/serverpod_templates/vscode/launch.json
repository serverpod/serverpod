{
  "version": "0.2.0",
  "configurations": [
    // {{#flutterApp}}
    // If the server pubspec configures multiple Flutter apps, add an attach
    // configuration like this for each app and add every configuration name
    // to the compound below. Use the VM-service info file pattern
    // `${workspaceFolder}/projectname_server/.dart_tool/serverpod/flutter-vm-service-info-<appId>.json`,
    // where `<appId>` is the app's key under `serverpod.flutter_apps` in the
    // server pubspec.
    {
      // Attaches to the Flutter app `serverpod start` spawns. Don't
      // launch a second instance here - it would race for the port.
      "name": "projectname_flutter",
      "type": "dart",
      "request": "attach",
      "vmServiceInfoFile": "${workspaceFolder}/projectname_server/.dart_tool/serverpod/flutter-vm-service-info-projectname.json",
      "preLaunchTask": "serverpod_start",
      "internalConsoleOptions": "neverOpen"
    },
    // {{/flutterApp}}
    {
      "name": "projectname_server",
      "type": "dart",
      "request": "attach",
      "vmServiceInfoFile": "${workspaceFolder}/projectname_server/.dart_tool/serverpod/vm-service-info.json",
      "preLaunchTask": "serverpod_start",
      "internalConsoleOptions": "neverOpen"
    }
    // {{#flutterApp}}
  ],
  "compounds": [
    {
      "name": "projectname (full stack)",
      "configurations": [
        "projectname_server",
        "projectname_flutter"
      ],
      // Stopping one session stops both; the orphan blocks re-attach.
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
    // {{/flutterApp}}
  ]
}

{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "projectname_flutter",
            "cwd": "${workspaceFolder}/projectname_flutter",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart"
        },
        {
            "name": "projectname_server",
            "cwd": "${workspaceFolder}/projectname_server",
            "request": "attach",
            "type": "dart",
            "preLaunchTask": "serverpod_start_watch",
            "vmServiceInfoFile": "${workspaceFolder}/projectname_server/.dart_tool/serverpod/vm-service-info.json"
        }
    ],
    "compounds": [
        {
            "name": "projectname (full stack)",
            "configurations": [
                "projectname_server",
                "projectname_flutter"
            ],
            "presentation": {
                "order": 1
            }
        }
    ]
}

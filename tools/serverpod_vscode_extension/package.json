{
  "name": "serverpod",
  "displayName": "Serverpod",
  "publisher": "Serverpod",
  "description": "Serverpod for VS code, manage your projects and get code feedback in real time.",
  "icon": "assets/icons/icon.png",
  "galleryBanner": {
    "color": "#020E24",
    "theme": "dark"
  },
  "version": "1.4.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "activationEvents:serverpod",
    "onDebug",
    "onDebugResolve:serverpod",
    "onDebugDynamicConfigurations:serverpod"
  ],
  "pricing": "Free",
  "homepage": "https://serverpod.dev",
  "bugs": {
    "url": "https://github.com/serverpod/serverpod/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/serverpod/serverpod.git"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "serverpod",
        "aliases": [
          "Serverpod yaml",
          "Spy"
        ],
        "extensions": [
          ".spy.yaml",
          ".spy.yml",
          ".spy"
        ],
        "configuration": "./syntaxes/language-configuration.json",
        "icon": {
          "light": "./assets/icons/icon.png",
          "dark": "./assets/icons/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "serverpod",
        "scopeName": "source.serverpod",
        "path": "./syntaxes/serverpod.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "serverpod",
        "label": "Serverpod",
        "languages": [
          "dart"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "vmServiceUri": {
                "type": "string",
                "description": "HTTP URI of the running pod's VM service. If omitted, vmServiceInfoFile is read instead."
              },
              "vmServiceInfoFile": {
                "type": "string",
                "description": "Path to the vm-service-info.json file written by `serverpod start --watch`. Defaults to ${workspaceFolder}/.dart_tool/serverpod/vm-service-info.json.",
                "default": "${workspaceFolder}/.dart_tool/serverpod/vm-service-info.json"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Attach to Serverpod",
            "type": "serverpod",
            "request": "attach"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Serverpod: Attach",
            "description": "Attach to a running `serverpod start --watch`. cwd and vmServiceInfoFile are auto-discovered; override either by adding the corresponding attribute, or set vmServiceUri for full manual control.",
            "body": {
              "name": "Attach to Serverpod",
              "type": "serverpod",
              "request": "attach"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "publish-vscode": "vsce publish",
    "publish-openvsx": "osvx publish",
    "build": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "25.0.3",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.75.1",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.37.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.2",
    "ovsx": "^0.10.5",
    "sinon": "^21.0.0",
    "typescript": "~5.9.3"
  }
}

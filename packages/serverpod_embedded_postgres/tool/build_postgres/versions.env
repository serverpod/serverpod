# Canonical bundle specification for the Serverpod PostgreSQL bundle
# (PostgreSQL + PostGIS + pgvector): every component version plus the bundle
# packaging revision. Single source of truth - the build scripts source this
# file, and bundle_spec_test.dart cross-checks it against the Dart constants
# in lib/src/binary/bundle_spec.dart so the shell and Dart sides cannot drift.
#
# PG_UPSTREAM_VERSION is upstream's two-part release number; PG_BOM is the
# three-part bill-of-materials version used in artifact names and cache keys.
#
# Published bundle identities are append-only. Bump BUNDLE_REVISION for ANY
# change that alters the shipped bundle while PG_BOM stays the same (extension
# bumps, compiler or packaging fixes) - a fix only reaches users whose cache
# already holds the previous bundle if it ships under a new revision.
PG_UPSTREAM_VERSION=16.13
PG_BOM=16.13.0
BUNDLE_REVISION=1
PGVECTOR_VERSION=0.8.3
POSTGIS_VERSION=3.5.4
GEOS_VERSION=3.13.0
PROJ_VERSION=9.5.1
SQLITE_VERSION=3.47.2
SQLITE_AUTOCONF=3470200
SQLITE_YEAR=2024
LIBXML2_VERSION=2.13.8
JSONC_VERSION=0.18

# SHA-256 pins of the upstream source archives, verified by fetch-sources.sh
# before extraction. The PostgreSQL hash matches the .sha256 sidecar
# published at ftp.postgresql.org for this release.
PG_SHA256=dc2ddbbd245c0265a689408e3d2f2f3f9ba2da96bd19318214b313cdd9797287
PGVECTOR_SHA256=dc080c511a6354a1628eb19f9bc8e77ce880dde16c889744a6814c8c0006e36c
POSTGIS_SHA256=bc960a0395942d58abb8078a09bb901bd49555565532f5246cc28292d9eadb57
GEOS_SHA256=47ec83ff334d672b9e4426695f15da6e6368244214971fabf386ff8ef6df39e4
PROJ_SHA256=a8395f9696338ffd46b0feb603edbb730fad6746fba77753c77f7f997345e3d3
SQLITE_SHA256=f1b2ee412c28d7472bc95ba996368d6f0cdcf00362affdadb27ed286c179540b
